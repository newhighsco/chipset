{
  "name": "@newhighsco/chipset",
  "description": "Shareable, theme-able component library by New High Score",
  "version": "7.4.0",
  "author": "New High Score",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/newhighsco/chipset.git"
  },
  "homepage": "https://github.com/newhighsco/chipset#readme",
  "bugs": {
    "url": "https://github.com/newhighsco/chipset/issues"
  },
  "packageManager": "yarn@4.17.1",
  "main": "src/index.js",
  "files": [
    "src",
    "styles"
  ],
  "storybook": {
    "url": "https://main--6004028a0df11e0021f58df8.chromatic.com"
  },
  "scripts": {
    "prepare": "husky",
    "start": "storybook dev --port 49928",
    "build": "storybook build --output-dir build --docs --quiet --webpack-stats-json",
    "pretest": "yarn lint",
    "test": "jest --runInBand",
    "test:list": "jest --listTests",
    "snapshot": "chromatic --storybook-build-dir build --auto-accept-changes main --exit-once-uploaded --only-changed",
    "lint": "concurrently 'yarn:lint:*'",
    "lint:js": "eslint --cache .",
    "lint:css": "stylelint --cache --ignore-path .gitignore '**/*.?(s)css'",
    "format": "concurrently 'yarn:format:*'",
    "format:js": "yarn lint:js --fix",
    "format:css": "yarn lint:css --fix"
  },
  "dependencies": {
    "@dr.pogodin/react-themes": "1.11.0",
    "@iconify/react": "6.0.2",
    "classnames": "2.5.1",
    "react-device-detect": "2.2.3",
    "url-join": "5.0.0"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@babel/preset-react": "8.0.1",
    "@commitlint/cli": "21.2.1",
    "@newhighsco/browserslist-config": "3.0.1",
    "@newhighsco/commitlint-config": "1.3.4",
    "@newhighsco/editor-config": "1.2.0",
    "@newhighsco/eslint-config": "7.1.26",
    "@newhighsco/lint-staged-config": "1.1.3",
    "@newhighsco/postcss-config": "4.0.68",
    "@newhighsco/prettier-config": "2.3.13",
    "@newhighsco/release-config": "1.5.9",
    "@newhighsco/storybook-preset": "10.2.73",
    "@newhighsco/stylelint-config": "4.0.54",
    "@newhighsco/svgr-config": "1.0.0",
    "@newhighsco/yarn-plugin-preset": "1.1.4",
    "@storybook/react-webpack5": "10.5.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "babel-loader": "10.1.1",
    "chromatic": "18.1.0",
    "concurrently": "10.0.3",
    "eslint": "10.7.0",
    "husky": "9.1.7",
    "identity-obj-proxy": "3.0.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-junit": "17.0.0",
    "lint-staged": "17.2.0",
    "prettier": "3.9.6",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "sass-true": "10.1.0",
    "semantic-release": "25.0.8",
    "storybook": "10.5.3",
    "stylelint": "17.14.1",
    "typescript": "6.0.3",
    "webpack": "5.109.0"
  },
  "peerDependencies": {
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "browserslist": [
    "extends @newhighsco/browserslist-config"
  ],
  "commitlint": {
    "extends": [
      "@newhighsco"
    ]
  },
  "prettier": "@newhighsco/prettier-config",
  "release": {
    "extends": "@newhighsco/release-config"
  },
  "stylelint": {
    "extends": [
      "@newhighsco/stylelint-config"
    ],
    "overrides": [
      {
        "files": [
          "**/*.spec.*"
        ],
        "rules": {
          "number-max-precision": null
        }
      }
    ],
    "rules": {
      "value-keyword-case": [
        "lower",
        {
          "camelCaseSvgKeywords": true,
          "ignoreKeywords": [
            "/(mobile|tablet)Landscape/",
            "/desktop(Medium|Large)/"
          ]
        }
      ]
    }
  }
}
